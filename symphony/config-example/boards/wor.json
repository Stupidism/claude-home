{
  "teamId": "YOUR_LINEAR_TEAM_UUID",
  "name": "Workstream",
  "ticketPrefix": "WOR",
  "ticketSystem": "linear",
  "code-review-comment": "@your-github-actions-bot review",
  "states": {
    "backlog":     "YOUR_BACKLOG_STATE_UUID",
    "todo":        "YOUR_TODO_STATE_UUID",
    "inProgress":  "YOUR_IN_PROGRESS_STATE_UUID",
    "humanReview": "YOUR_HUMAN_REVIEW_STATE_UUID",
    "inReview":    "YOUR_IN_REVIEW_STATE_UUID",
    "rework":      "YOUR_REWORK_STATE_UUID",
    "merging":     "YOUR_MERGING_STATE_UUID",
    "done":        "YOUR_DONE_STATE_UUID"
  },
  "defaultRepo": "workstream-mono",
  "repos": [
    {
      "name": "workstream-mono",
      "description": "NX monorepo containing all frontend MFE sub-apps and corresponding BFFs.",
      "path": "~/Documents/workstream-mono",
      "worktreesDir": "~/Documents/workstream-mono-worktrees",
      "defaultBranch": "master",
      "github": "your-org/workstream-mono",
      "isMono": true,
      "setup": {
        "symlinkNodeModules": true,
        "installCommand": "CI=true pnpm install --frozen-lockfile --quiet",
        "installCheck": "pnpm-lock.yaml"
      }
    }
  ],
  "projects": [
    {
      "linearProjectId": "YOUR_PROJECT_UUID",
      "name": "Frontend KTLO",
      "primaryRepo": "workstream-mono",
      "repos": [
        {
          "name": "workstream-mono",
          "path": "~/Documents/workstream-mono",
          "hint": "Frontend tech-debt and maintenance tasks; start from monorepo root and explore from there."
        }
      ]
    }
  ]
}
